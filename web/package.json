{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:local": "vite --mode local-integration --host",
		"build": "vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173 --ip 0.0.0.0",
		"prepare": "cd .. && husky web/.husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"test": "vitest run --project=unit",
		"test:watch": "vitest --project=unit",
		"test:coverage": "vitest run --project=unit --coverage",
		"test:all": "vitest run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"lint-staged": {
		"*.{ts,js,svelte}": "eslint",
		"*.{ts,js,svelte,css,html,json}": "prettier --check"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.5",
		"@storybook/sveltekit": "^10.3.5",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/eslint-plugin-query": "^5.97.0",
		"@tanstack/svelte-query-devtools": "^6.1.14",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-storybook": "^10.3.5",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"msw": "^2.13.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.5",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"wrangler": "^4.63.0"
	},
	"dependencies": {
		"@material-symbols/svg-400": "^0.42.3",
		"@poppanator/sveltekit-svg": "^6.0.1",
		"@tanstack/svelte-query": "^6.1.14",
		"axios": "^1.15.0",
		"bits-ui": "^2.17.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^3.25.76"
	},
	"msw": {
		"workerDirectory": [
			"static"
		]
	}
}
